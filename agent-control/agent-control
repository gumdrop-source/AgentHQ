#!/usr/bin/env bash
# agent-control — provision and manage agents on this AgentHQ host
#
# Usage:
#   sudo agent-control create <name> --tools t1,t2,... [--persona "..."] [--telegram-chat-id N]
#   sudo agent-control delete <name> [--purge]
#   sudo agent-control list
#
# create:
#   - useradd <name> in the agents group with home /home/<name>
#   - render config templates from /opt/agents/templates/ into the home
#   - install claude binary as the agent user (per-agent install)
#   - write systemd credential drop-in based on enabled tools
#   - enable + start agent@<name>.service
#
# delete:
#   - stop and disable agent@<name>.service
#   - remove the systemd drop-in directory
#   - userdel (or userdel --remove with --purge to wipe home + memory)
#
# list:
#   - print one row per agent: name, service status, enabled tools

set -euo pipefail

PLATFORM_ROOT=/opt/agents
TEMPLATES="$PLATFORM_ROOT/templates"
CRED_VAULT=/etc/agents/credentials
CLAUDE_INSTALL_URL="https://claude.ai/install.sh"

log() { echo "[agent-control] $*"; }
die() { echo "agent-control: $*" >&2; exit 1; }
require_root() { [[ $EUID -eq 0 ]] || die "must run as root (use sudo)"; }

# ─── helpers ──────────────────────────────────────────────────────────────

# Replace {{KEY}} placeholders. Sed delimiter is | so values must not contain |.
render_template() {
    local file="$1"; shift
    local args=()
    while (($# > 0)); do
        local kv="$1"; shift
        local k="${kv%%=*}" v="${kv#*=}"
        args+=(-e "s|{{$k}}|$v|g")
    done
    sed "${args[@]}" "$file"
}

# comma-separated string → TOML array literal: ["a", "b"]
#
# Note: `local IFS=','` and the array initialization MUST be on separate
# statements. The single-line form `local IFS=',' parts=($1)` doesn't
# split on comma because the IFS assignment has not taken effect at the
# point bash evaluates `($1)` (both are arguments to the same `local`
# builtin invocation, so the new IFS is scoped to that command's args
# but applied AFTER expansion). Splitting on whitespace silently yields
# a single-element array for typical comma-only inputs.
toml_list() {
    local IFS=','
    local parts=($1) out="[" first=1 p
    for p in "${parts[@]}"; do
        (( first )) && first=0 || out+=", "
        p="${p// /}"
        out+="\"$p\""
    done
    echo "$out]"
}

# comma-separated string → JSON object: {"a": true, "b": true}
mcp_servers_json() {
    local IFS=','
    local parts=($1) out="{" first=1 p
    for p in "${parts[@]}"; do
        (( first )) && first=0 || out+=", "
        p="${p// /}"
        out+="\"$p\": true"
    done
    echo "$out}"
}

# Per-tool credential lists. Used by both write_agent_credentials_dropin
# (telegram bot token only — agent-prelaunch needs it to materialise
# ~/.claude/channels/telegram/.env) and write_mcp_credentials_dropin
# (everything else — only the trusted -mcp peer should see these).
#
# Format: "tool:cred_name[:agent-prefix]" — when agent-prefix is "1", the
# cred is per-agent and stored under <agent>_<cred_name>.cred. Otherwise
# it's shared across agents under <cred_name>.cred.
mcp_creds_for_tools() {
    local name="$1" tools="$2"
    local agent_prefix="$name"

    if [[ ",$tools," == *,m365,* ]]; then
        echo "m365_tenant_id"
        echo "m365_client_id"
        echo "m365_client_secret"
    fi
    if [[ ",$tools," == *,gmail,* ]]; then
        echo "${agent_prefix}_gmail_user"
        echo "${agent_prefix}_gmail_pass"
    fi
    if [[ ",$tools," == *,myob,* ]]; then
        # myob_refresh_token is intentionally NOT listed: per-user mode
        # means each Telegram user runs their own OAuth dance, so the
        # platform-level refresh token is optional. If the operator has
        # set one anyway (legacy or admin-direct-mode), the existsSync
        # filter below picks it up and includes it.
        echo "myob_client_id"
        echo "myob_client_secret"
        echo "myob_business_id"
    fi
    if [[ ",$tools," == *,hikvision,* ]]; then
        echo "hikvision_user"
        echo "hikvision_pass"
    fi
    if [[ ",$tools," == *,homeassistant,* ]] || [[ ",$tools," == *,ha,* ]]; then
        echo "ha_token"
    fi
    if [[ ",$tools," == *,gigafy_portal,* ]]; then
        echo "portal_api_user"
        echo "portal_api_pass"
        echo "portal_reseller_id"
    fi
}

# Drop-in for agent@<name>.service.d/. The agent unit only needs the
# telegram bot token — agent-prelaunch reads it to render
# ~/.claude/channels/telegram/.env so the bot can poll Telegram.
#
# Decision: keeping this one cred loaded into the agent unit is the
# pragmatic choice. The Claude process fundamentally needs to talk to
# Telegram on behalf of the user, so a compromised LLM can already
# exfiltrate via that connection — re-isolating the bot token under the
# -mcp peer would only stop the value being read directly, not stop
# misuse. Documented in docs/architecture.md.
write_agent_credentials_dropin() {
    local name="$1" tools="$2"
    echo "# Auto-generated by agent-control — do not edit by hand."
    echo "# Regenerate by re-running: agent-control create $name --tools $tools"
    echo "# Only the telegram bot token is loaded here; all other creds go to"
    echo "# agent-mcp-creds@$name.service (see Option A — credential isolation)."
    echo "[Service]"
    if [[ ",$tools," == *,telegram,* ]]; then
        echo "LoadCredentialEncrypted=${name}_telegram_bot_token:$CRED_VAULT/${name}_telegram_bot_token.cred"
    fi
}

# Drop-in for agent-mcp-creds@<name>.service.d/. Loads every NON-telegram
# credential the agent's tools need. systemd decrypts these as the -mcp
# user; agent-mcp-creds-install then mirrors them to /run/agents/<name>-mcp/
# credentials/, which the agent user cannot read.
write_mcp_credentials_dropin() {
    local name="$1" tools="$2"
    echo "# Auto-generated by agent-control — do not edit by hand."
    echo "# Regenerate by re-running: agent-control create $name --tools $tools"
    echo "[Service]"
    local cred
    while IFS= read -r cred; do
        [[ -n "$cred" ]] || continue
        # systemd-creds embeds the credential name at encrypt time and
        # refuses to load when the runtime name differs from the embedded
        # one. So filename, encrypted name, and runtime name must all match.
        echo "LoadCredentialEncrypted=${cred}:$CRED_VAULT/${cred}.cred"
    done < <(mcp_creds_for_tools "$name" "$tools")

    # Optional creds — listed per tool, only emitted if their .cred file
    # actually exists in the vault. Lets a tool declare credentials that
    # are nice-to-have-but-not-required (e.g. myob_refresh_token, where
    # per-user mode is the default and the platform token is just a
    # convenience for direct/admin access). Without this filter, a
    # missing optional cred file would block the unit from starting.
    while IFS= read -r cred; do
        [[ -n "$cred" ]] || continue
        [[ -f "$CRED_VAULT/$cred.cred" ]] || continue
        echo "LoadCredentialEncrypted=${cred}:$CRED_VAULT/${cred}.cred"
    done < <(mcp_optional_creds_for_tools "$name" "$tools")
}

# Optional creds — only loaded if the operator chose to provide them.
# Same shape as mcp_creds_for_tools (one cred name per line); the
# filter in write_mcp_credentials_dropin drops missing entries.
mcp_optional_creds_for_tools() {
    local name="$1" tools="$2"
    if [[ ",$tools," == *,myob,* ]]; then
        echo "myob_refresh_token"
    fi
    if [[ ",$tools," == *,gigafy_portal,* ]]; then
        echo "portal_api_url"
    fi
}

# Drop-in to make agent@<name>.service start *after* its credential
# decryption peer. Requires= ensures we don't start the agent if creds
# failed to materialise (rather than starting it with no creds and
# hitting permission errors on every tool call).
write_agent_order_dropin() {
    cat <<'EOF'
# Auto-generated by agent-control — do not edit by hand.
# Sequences the paired-user credential service before the agent.
[Unit]
Requires=agent-mcp-creds@%i.service
After=agent-mcp-creds@%i.service
EOF
}

# /etc/sudoers.d/agent-<name>: lets the agent user invoke ONE binary as
# the -mcp peer, with no password and no env passthrough. visudo -cf
# checks the file for syntax errors before installing — a bad sudoers
# file can wedge sudo entirely on the box.
write_sudoers_fragment() {
    local name="$1"
    cat <<EOF
# Auto-generated by agent-control — do not edit by hand.
# AgentHQ Option A — paired-user credential isolation.
#
# Allow the agent user to spawn the credential-bearing MCP launcher as
# its trusted -mcp peer. The launcher itself is the choke point: it
# validates the requested server against /home/$name/agent.toml and
# refuses anything else.
$name ALL=($name-mcp) NOPASSWD: /opt/agents/bin/agent-mcp-launcher
EOF
}

# Generate /home/<name>/.mcp.json from the enabled tool list. Each entry's
# command is /usr/bin/sudo and its args invoke the launcher under the
# -mcp peer. -n makes sudo fail-fast rather than ever prompting.
write_mcp_json() {
    local name="$1" tools="$2" home="$3"
    local IFS=','
    local parts=($tools) p first=1 entries=""
    for p in "${parts[@]}"; do
        p="${p// /}"
        # `telegram` is delivered as a claude plugin, not as a tools/<id>/
        # MCP server. Skip it here — it's wired up via plugin config.
        [[ "$p" == "telegram" ]] && continue
        # Only emit entries for tools that have a tool dir staged on this
        # box. Otherwise claude would discover a server that immediately
        # fails when it tries to spawn the launcher's exec target.
        [[ -d "/opt/agents/tools/$p" ]] || continue
        (( first )) && first=0 || entries+=","
        entries+="
    \"$p\": {
      \"type\": \"stdio\",
      \"command\": \"/usr/bin/sudo\",
      \"args\": [\"-u\", \"$name-mcp\", \"-n\", \"/opt/agents/bin/agent-mcp-launcher\", \"$p\"]
    }"
    done
    cat <<EOF
{
  "mcpServers": {$entries
  }
}
EOF
}

# ─── subcommands ──────────────────────────────────────────────────────────

cmd_create() {
    local name="" tools="" persona="" telegram_chat_id=""
    while (($# > 0)); do
        case "$1" in
            --tools)             tools="$2"; shift 2;;
            --persona)           persona="$2"; shift 2;;
            --telegram-chat-id)  telegram_chat_id="$2"; shift 2;;
            -*)                  die "unknown flag: $1";;
            *)
                [[ -z "$name" ]] && { name="$1"; shift; } || die "extra positional arg: $1"
                ;;
        esac
    done

    [[ -n "$name" ]]  || die "usage: agent-control create <name> --tools t1,t2,..."
    [[ "$name" =~ ^[a-z][a-z0-9_-]{1,30}$ ]] || die "invalid agent name '$name' (must start with [a-z], 2-31 chars, [a-z0-9_-])"
    [[ -n "$tools" ]] || die "--tools is required (e.g. --tools m365,gmail,telegram)"
    [[ -d "$TEMPLATES" ]] || die "templates not staged at $TEMPLATES — run AgentHQ install"

    id "$name" >/dev/null 2>&1 && die "user '$name' already exists — pick another name or 'agent-control delete $name --purge' first"
    [[ -d "/home/$name" ]] && die "/home/$name already exists"

    log "Creating agent '$name'"
    log "  tools:    $tools"
    log "  persona:  ${persona:-<none>}"
    log "  tg chat:  ${telegram_chat_id:-<none>}"

    # 1. Linux users — paired-user model (Option A: credential isolation).
    #    <name>      runs Claude (untrusted side; no creds readable).
    #    <name>-mcp  runs MCP servers (trusted side; holds decrypted creds).
    log "useradd $name (agent / untrusted side)"
    useradd --create-home --shell /bin/bash --groups agents "$name"
    local home="/home/$name"

    log "useradd $name-mcp (MCP / trusted side, system user)"
    # Membership in <name> (the agent's user-private group) lets the -mcp
    # peer traverse /home/<name> to read agent.toml without making the
    # home directory world-readable. The launcher needs that file to
    # validate which servers it's allowed to spawn.
    useradd --system --user-group --no-create-home \
            --shell /usr/sbin/nologin \
            --groups "agents,$name" "$name-mcp"
    # Per-MCP-user HOME so MCP servers that write per-agent token caches
    # (m365 keeps a refresh token under $HOME/.m365_token_cache.json) can
    # do so on the trusted side rather than in the agent's claude-readable
    # home directory.
    install -d -m 0700 -o "$name-mcp" -g "$name-mcp" "/var/lib/agents/$name-mcp"

    # 2. Home dir tree
    log "Creating home tree"
    sudo -u "$name" mkdir -p "$home/memory" "$home/skills" "$home/logs" "$home/.claude"

    # 3. Install claude binary first — we need its version string when
    #    rendering claude-config.json (lastOnboardingVersion has to match
    #    what's installed or the onboarding gate doesn't take).
    log "Installing claude binary as $name (~30s, ~240 MB)"
    # Surface installer output (kept brief by piping through grep) so the
    # web wizard's SSE stream doesn't go silent for 30s — silent connections
    # get reaped by EventSource auto-reconnect, which re-fires this whole
    # function and trips 'user already exists' on the second attempt.
    sudo -u "$name" -H bash -c "curl -fsSL $CLAUDE_INSTALL_URL | bash" 2>&1 \
        | grep --line-buffered -E '%|installing|Installing|claude' || true

    local claude_version
    claude_version="$(ls -1 "$home/.local/share/claude/versions/" 2>/dev/null | sort -V | tail -1 || true)"
    [[ -n "$claude_version" ]] || die "claude install did not produce $home/.local/share/claude/versions/"
    log "Claude installed: $claude_version"

    # 4. Render templates
    log "Rendering config from $TEMPLATES"
    render_template "$TEMPLATES/agent.toml.tmpl" \
        "AGENT_NAME=$name" \
        "AGENT_HOME=$home" \
        "AGENT_PERSONA=${persona//\"/\\\"}" \
        "TELEGRAM_CHAT_ID=$telegram_chat_id" \
        "TOOLS_LIST_TOML=$(toml_list "$tools")" \
        > "$home/agent.toml"

    render_template "$TEMPLATES/claude-config.json.tmpl" \
        "CLAUDE_VERSION=$claude_version" \
        "AGENT_HOME=$home" \
        "ENABLED_MCP_SERVERS_JSON=$(mcp_servers_json "$tools")" \
        > "$home/.claude.json"

    cp "$TEMPLATES/settings.json.tmpl" "$home/.claude/settings.json"

    # CLAUDE.md — operating instructions for the agent (anti-hallucination,
    # tool honesty, destructive-confirmation, credential safety). Read by
    # claude-code at session start.
    #
    # Rendered via Python rather than sed because the persona block can
    # contain newlines, quotes, $ and other chars that break sed's s///
    # delimiters. Python str.replace handles arbitrary input.
    if [[ -f "$TEMPLATES/CLAUDE.md.tmpl" ]]; then
        local persona_block=""
        if [[ -n "$persona" ]]; then
            persona_block="## Your persona"$'\n\n'"$persona"
        fi
        AGENT_NAME="$name" \
        AGENT_PERSONA_BLOCK="$persona_block" \
        TELEGRAM_CHAT_ID="$telegram_chat_id" \
        TEMPLATE_PATH="$TEMPLATES/CLAUDE.md.tmpl" \
        OUTPUT_PATH="$home/CLAUDE.md" \
        python3 -c '
import os
content = open(os.environ["TEMPLATE_PATH"]).read()
for k in ("AGENT_NAME", "AGENT_PERSONA_BLOCK", "TELEGRAM_CHAT_ID"):
    content = content.replace("{{" + k + "}}", os.environ.get(k, ""))
open(os.environ["OUTPUT_PATH"], "w").write(content)
'
    fi

    # 4a. Telegram allowlist — empty file means the bot ignores every message.
    # When --telegram-chat-id was given, render an access.json so this chat
    # can talk to the bot from the first message.
    if [[ "$tools" == *"telegram"* && -n "$telegram_chat_id" ]]; then
        log "Rendering telegram access.json (allowlist: $telegram_chat_id)"
        sudo -u "$name" mkdir -p "$home/.claude/channels/telegram"
        sudo -u "$name" tee "$home/.claude/channels/telegram/access.json" >/dev/null <<EOF
{"dmPolicy":"allowlist","allowFrom":["$telegram_chat_id"],"groups":{},"pending":{}}
EOF
    fi

    chown -R "$name:$name" "$home/agent.toml" "$home/.claude.json" "$home/.claude"

    # 4b. Authenticate claude. The binary is installed but has no Anthropic
    # OAuth token, so without this step the bot would receive messages and
    # silently fail when it tries to call the API.
    #
    # When run from the web wizard, the env var AGENTHQ_SKIP_CLAUDE_LOGIN=1
    # tells us the wizard is taking responsibility for the login step on
    # its own page (since the OAuth flow is interactive and TTY-bound, it
    # can't run as a child of a non-interactive subprocess).
    if [[ -f "$home/.claude/.credentials.json" ]]; then
        log "Claude already authenticated for $name — skipping login"
    elif [[ "${AGENTHQ_SKIP_CLAUDE_LOGIN:-}" == "1" ]]; then
        log "Skipping claude login (AGENTHQ_SKIP_CLAUDE_LOGIN=1) — caller will handle"
    else
        log "Authenticating claude as $name — interactive login required"
        cat <<EOF

────────────────────────────────────────────────────────────
The next step is interactive. Claude will open a TUI and walk
you through OAuth login (URL → browser → paste code back).

When done, type  /exit  in claude (or press Ctrl-C twice) to
return to this script. Press Enter to begin...
────────────────────────────────────────────────────────────
EOF
        read -r _
        sudo -i -u "$name" -- claude </dev/tty >/dev/tty 2>&1 || true
        if [[ ! -f "$home/.claude/.credentials.json" ]]; then
            log "WARNING: claude credentials.json still missing — login did not complete"
            log "Service will fail to respond until you run: sudo -i -u $name claude"
        else
            log "Claude authenticated for $name"
        fi
    fi

    # 5a. .mcp.json — sudo-wraps each MCP server so claude (running as
    # <name>) launches it via the trusted -mcp peer, not directly.
    log "Writing $home/.mcp.json (sudo-wrapped MCP entries)"
    write_mcp_json "$name" "$tools" "$home" > "$home/.mcp.json"
    chown "$name:$name" "$home/.mcp.json"
    chmod 0644 "$home/.mcp.json"

    # 5b. Systemd credential drop-ins — split between the two units.
    # Telegram bot token stays on the agent unit (agent-prelaunch reads
    # it to write the telegram plugin .env). All other creds are loaded
    # ONLY by the -mcp peer's decrypt service.
    log "Writing systemd credential drop-ins"
    local agent_dropin_dir="/etc/systemd/system/agent@$name.service.d"
    local mcp_dropin_dir="/etc/systemd/system/agent-mcp-creds@$name.service.d"
    mkdir -p "$agent_dropin_dir" "$mcp_dropin_dir"

    write_agent_credentials_dropin "$name" "$tools" > "$agent_dropin_dir/credentials.conf"
    chmod 0644 "$agent_dropin_dir/credentials.conf"

    write_agent_order_dropin                       > "$agent_dropin_dir/order.conf"
    chmod 0644 "$agent_dropin_dir/order.conf"

    write_mcp_credentials_dropin "$name" "$tools"  > "$mcp_dropin_dir/credentials.conf"
    chmod 0644 "$mcp_dropin_dir/credentials.conf"

    # 5c. /etc/sudoers.d/agent-<name>. Validate via visudo -cf BEFORE
    # moving into /etc/sudoers.d/ — a syntax-broken file in that dir can
    # wedge sudo for the whole box, including for us.
    log "Installing /etc/sudoers.d/agent-$name"
    local sudoers_tmp
    sudoers_tmp="$(mktemp)"
    write_sudoers_fragment "$name" > "$sudoers_tmp"
    chmod 0440 "$sudoers_tmp"
    if ! visudo -cf "$sudoers_tmp" >/dev/null; then
        rm -f "$sudoers_tmp"
        die "generated sudoers fragment failed visudo -cf — refusing to install"
    fi
    install -m 0440 -o root -g root "$sudoers_tmp" "/etc/sudoers.d/agent-$name"
    rm -f "$sudoers_tmp"

    # 6. Enable services. agent-mcp-creds@ must be enabled regardless of
    # whether creds are present — at start time it'll fail loudly if any
    # are missing, which is what we want (better than starting the agent
    # against an empty cred dir and getting opaque tool errors).
    systemctl daemon-reload
    systemctl enable "agent-mcp-creds@$name.service"

    local -a missing=()
    local f
    for f in "$agent_dropin_dir/credentials.conf" "$mcp_dropin_dir/credentials.conf"; do
        while IFS= read -r line; do
            [[ "$line" =~ ^LoadCredentialEncrypted=([^:]+):(.+)$ ]] || continue
            local cred_path="${BASH_REMATCH[2]}"
            [[ -f "$cred_path" ]] || missing+=("$(basename "${cred_path%.cred}")")
        done < "$f"
    done

    if (( ${#missing[@]} == 0 )); then
        log "All required credentials present — enabling and starting services"
        systemctl start "agent-mcp-creds@$name.service"
        systemctl enable --now "agent@$name.service"
        systemctl --no-pager status "agent@$name.service" | head -6 || true
        echo
        log "Agent '$name' is up."
    else
        log "Enabling agent service (will start on boot once creds are present)"
        systemctl enable "agent@$name.service"
        echo
        echo "Agent '$name' provisioned but service NOT started — missing credentials:"
        for c in "${missing[@]}"; do
            echo "  - $c"
        done
        echo
        echo "Inject each one into the vault, then start the services:"
        for c in "${missing[@]}"; do
            echo "    sudo agenthq-cred set $c       # paste value, Ctrl-D"
        done
        echo "    sudo systemctl start agent-mcp-creds@$name.service"
        echo "    sudo systemctl start agent@$name.service"
    fi
}

cmd_delete() {
    local name="${1:-}" purge=0
    [[ -n "$name" ]] || die "usage: agent-control delete <name> [--purge]"
    [[ "${2:-}" == "--purge" ]] && purge=1

    id "$name" >/dev/null 2>&1 || die "no such user: $name"

    log "Deleting agent '$name'"
    systemctl disable --now "agent@$name.service"           2>/dev/null || true
    systemctl disable --now "agent-mcp-creds@$name.service" 2>/dev/null || true
    rm -rf "/etc/systemd/system/agent@$name.service.d"
    rm -rf "/etc/systemd/system/agent-mcp-creds@$name.service.d"
    rm -f  "/etc/sudoers.d/agent-$name"
    systemctl daemon-reload

    # The trusted -mcp peer is a system user with no home, but it does
    # own /var/lib/agents/<name>-mcp/ for token caches. Always remove
    # both — independent of --purge — since the peer has no value
    # without the agent it's paired with.
    if id "$name-mcp" >/dev/null 2>&1; then
        log "userdel $name-mcp"
        userdel "$name-mcp" 2>&1 | grep -v "mail spool" >&2 || true
    fi
    rm -rf "/var/lib/agents/$name-mcp"

    if (( purge )); then
        log "Removing user and home (purge)"
        userdel --remove "$name" 2>&1 | grep -v "mail spool" >&2 || true
        # Also wipe agent-prefixed credentials from the vault so a later
        # re-create can't silently use stale tokens. Shared creds (m365_*,
        # hikvision_*, ha_token, myob_*) stay — they're not per-agent.
        local creds_removed=0
        for cred in /etc/agents/credentials/${name}_*.cred; do
            [[ -f "$cred" ]] || continue
            rm -f "$cred"
            creds_removed=$((creds_removed + 1))
        done
        if (( creds_removed > 0 )); then
            log "Removed $creds_removed per-agent credential(s) from vault"
        fi
    else
        log "Removing user (home preserved at /home/$name — pass --purge to wipe)"
        userdel "$name"
    fi
    log "Agent '$name' deleted"
}

cmd_list() {
    printf '%-20s %-10s %s\n' NAME STATUS TOOLS
    printf '%-20s %-10s %s\n' "----" "------" "-----"
    local home name status tools
    for home in /home/*/; do
        name="$(basename "$home")"
        [[ -f "$home/agent.toml" ]] || continue
        if systemctl is-active --quiet "agent@$name.service" 2>/dev/null; then
            status="active"
        elif systemctl is-enabled --quiet "agent@$name.service" 2>/dev/null; then
            status="enabled"
        else
            status="stopped"
        fi
        tools="$(awk -F= '/^enabled[[:space:]]*=/{print $2; exit}' "$home/agent.toml" | sed 's/^[[:space:]]*//')"
        printf '%-20s %-10s %s\n' "$name" "$status" "${tools:-<none>}"
    done
}

# ─── dispatch ─────────────────────────────────────────────────────────────

case "${1:-}" in
    create) require_root; shift; cmd_create "$@" ;;
    delete) require_root; shift; cmd_delete "$@" ;;
    list)   shift; cmd_list "$@" ;;
    ""|-h|--help)
        sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
        ;;
    *) die "unknown command: $1 (try --help)" ;;
esac
