#!/usr/bin/env bash
# migrate-to-paired-users <agent>
#
# Convert an existing single-user agent (pre-Option-A) into the paired-user
# layout in place. Idempotent — safe to re-run after partial failures and
# safe to re-run on agents already migrated.
#
# What it does:
#   1. Creates the trusted -mcp peer if missing
#   2. Installs /etc/sudoers.d/agent-<name> (visudo -cf checked)
#   3. Splits the credentials drop-in:
#        agent@<name>.service.d/credentials.conf      → telegram only
#        agent-mcp-creds@<name>.service.d/credentials.conf → everything else
#   4. Writes the agent@.service.d/order.conf so agent waits on creds
#   5. Rewrites /home/<name>/.mcp.json so each MCP server is sudo-wrapped
#      through the launcher
#   6. Restarts both services in the right order
#
# What it does NOT do:
#   * Wipe or rotate any credential
#   * Touch any agent that's not on disk
#   * Push to other hosts — this is local only

set -euo pipefail

LOG_TAG="migrate-to-paired-users"
log() { echo "[$LOG_TAG] $*"; }
die() { echo "$LOG_TAG: $*" >&2; exit 1; }

[[ $EUID -eq 0 ]] || die "must run as root (use sudo)"

agent="${1:-}"
[[ -n "$agent" ]] || die "usage: migrate-to-paired-users <agent>"
[[ "$agent" =~ ^[a-z][a-z0-9_-]{1,30}$ ]] || die "invalid agent name '$agent'"
id "$agent" >/dev/null 2>&1 || die "no such user: $agent"
[[ -f "/home/$agent/agent.toml" ]] || die "/home/$agent/agent.toml missing — is this an AgentHQ agent?"

CRED_VAULT=/etc/agents/credentials
agent_unit_dir="/etc/systemd/system/agent@$agent.service.d"
mcp_unit_dir="/etc/systemd/system/agent-mcp-creds@$agent.service.d"

# ─── 1. trusted peer user ────────────────────────────────────────────────

if id "$agent-mcp" >/dev/null 2>&1; then
    log "$agent-mcp user already exists — ensuring group membership is current"
    # Guarantee the supplementary groups even on re-run (idempotent).
    usermod -a -G "agents,$agent" "$agent-mcp"
else
    log "useradd $agent-mcp"
    useradd --system --user-group --no-create-home \
            --shell /usr/sbin/nologin \
            --groups "agents,$agent" "$agent-mcp"
fi
install -d -m 0700 -o "$agent-mcp" -g "$agent-mcp" "/var/lib/agents/$agent-mcp"

# ─── 2. sudoers fragment ─────────────────────────────────────────────────

sudoers_path="/etc/sudoers.d/agent-$agent"
sudoers_tmp="$(mktemp)"
cat > "$sudoers_tmp" <<EOF
# Auto-generated by migrate-to-paired-users — do not edit by hand.
# AgentHQ Option A — paired-user credential isolation.
$agent ALL=($agent-mcp) NOPASSWD: /opt/agents/bin/agent-mcp-launcher
EOF
chmod 0440 "$sudoers_tmp"
if ! visudo -cf "$sudoers_tmp" >/dev/null; then
    rm -f "$sudoers_tmp"
    die "generated sudoers fragment failed visudo -cf"
fi
install -m 0440 -o root -g root "$sudoers_tmp" "$sudoers_path"
rm -f "$sudoers_tmp"
log "sudoers: $sudoers_path"

# ─── 3. split credential drop-in ─────────────────────────────────────────

mkdir -p "$agent_unit_dir" "$mcp_unit_dir"

# Read the existing combined drop-in (if any) and partition by cred name.
old_combined="$agent_unit_dir/credentials.conf"
declare -a tg_lines=() mcp_lines=()

if [[ -f "$old_combined" ]]; then
    while IFS= read -r line; do
        [[ "$line" =~ ^LoadCredentialEncrypted=([^:]+):(.+)$ ]] || continue
        local_name="${BASH_REMATCH[1]}"
        local_path="${BASH_REMATCH[2]}"
        if [[ "$local_name" == "${agent}_telegram_bot_token" ]]; then
            tg_lines+=("LoadCredentialEncrypted=$local_name:$local_path")
        else
            mcp_lines+=("LoadCredentialEncrypted=$local_name:$local_path")
        fi
    done < "$old_combined"
else
    log "no existing $old_combined to split — assuming nothing to migrate from there"
fi

# Telegram bot token: if the cred file exists in the vault but isn't yet
# represented in the drop-in, add it (covers agents created via earlier
# code paths that didn't always write it explicitly).
tg_cred="$CRED_VAULT/${agent}_telegram_bot_token.cred"
if [[ -f "$tg_cred" && ${#tg_lines[@]} -eq 0 ]]; then
    tg_lines+=("LoadCredentialEncrypted=${agent}_telegram_bot_token:$tg_cred")
fi

{
    echo "# Auto-generated by migrate-to-paired-users — do not edit by hand."
    echo "# Telegram bot token only; tool creds live in agent-mcp-creds@$agent.service."
    echo "[Service]"
    for l in "${tg_lines[@]:-}"; do [[ -n "$l" ]] && echo "$l"; done
} > "$agent_unit_dir/credentials.conf"
chmod 0644 "$agent_unit_dir/credentials.conf"

{
    echo "# Auto-generated by migrate-to-paired-users — do not edit by hand."
    echo "[Service]"
    for l in "${mcp_lines[@]:-}"; do [[ -n "$l" ]] && echo "$l"; done
} > "$mcp_unit_dir/credentials.conf"
chmod 0644 "$mcp_unit_dir/credentials.conf"

log "split credentials: $agent_unit_dir/credentials.conf (tg-only) + $mcp_unit_dir/credentials.conf (rest)"

# ─── 4. ordering drop-in ─────────────────────────────────────────────────

cat > "$agent_unit_dir/order.conf" <<'EOF'
# Auto-generated by migrate-to-paired-users — do not edit by hand.
# Sequences the paired-user credential service before the agent.
[Unit]
Requires=agent-mcp-creds@%i.service
After=agent-mcp-creds@%i.service
EOF
chmod 0644 "$agent_unit_dir/order.conf"
log "ordering: $agent_unit_dir/order.conf"

# ─── 5. rewrite .mcp.json ────────────────────────────────────────────────

mcp_json="/home/$agent/.mcp.json"
if [[ -f "$mcp_json" ]]; then
    log "rewriting $mcp_json (sudo-wrapping every MCP server entry)"
    python3 - "$mcp_json" "$agent" <<'PY'
import json, sys, os
path, agent = sys.argv[1], sys.argv[2]
with open(path) as f:
    data = json.load(f)
servers = data.get("mcpServers", {})
for name in list(servers.keys()):
    servers[name] = {
        "type": "stdio",
        "command": "/usr/bin/sudo",
        "args": ["-u", f"{agent}-mcp", "-n", "/opt/agents/bin/agent-mcp-launcher", name],
    }
data["mcpServers"] = servers
tmp = path + ".tmp"
with open(tmp, "w") as f:
    json.dump(data, f, indent=2)
os.replace(tmp, path)
PY
    chown "$agent:$agent" "$mcp_json"
    chmod 0644 "$mcp_json"
else
    log "no $mcp_json to rewrite (agent has no managed MCP integrations yet)"
fi

# ─── 6. restart services in the right order ──────────────────────────────

systemctl daemon-reload
systemctl enable "agent-mcp-creds@$agent.service"

# Stop+start instead of restart: agent-mcp-creds@ is oneshot+RemainAfterExit
# and won't re-run ExecStart on restart alone.
log "starting agent-mcp-creds@$agent.service"
systemctl stop  "agent-mcp-creds@$agent.service" 2>/dev/null || true
systemctl start "agent-mcp-creds@$agent.service" || die "agent-mcp-creds@$agent failed to start — check journalctl -u agent-mcp-creds@$agent"

if systemctl is-active --quiet "agent@$agent.service"; then
    log "restarting agent@$agent.service"
    systemctl restart "agent@$agent.service"
else
    log "agent@$agent.service was not active — leaving it stopped"
fi

log "migration complete for $agent"
log "verify: sudo -u $agent cat /run/agents/$agent-mcp/credentials/<any> should fail"
