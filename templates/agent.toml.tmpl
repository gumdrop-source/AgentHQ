# AgentHQ — per-agent configuration
# Rendered by agent-control at `agent-control create <name>` time.

[agent]
name = "{{AGENT_NAME}}"
home = "{{AGENT_HOME}}"
persona = "{{AGENT_PERSONA}}"

[telegram]
chat_id = "{{TELEGRAM_CHAT_ID}}"
# Credential name in /etc/agents/credentials/
bot_token_cred = "{{AGENT_NAME}}_telegram_bot_token"

[tools]
# Tools this agent is allowed to invoke. Must each exist under /opt/agents/tools/.
enabled = {{TOOLS_LIST_TOML}}
